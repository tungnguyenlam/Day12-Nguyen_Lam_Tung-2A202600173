# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=Production AI Agent
APP_VERSION=2.0.0

# Authentication — BẮT BUỘC thay trong production
AGENT_API_KEY=replace-with-a-long-random-api-key

# Provider defaults
CHATBOT_DEFAULT_PROVIDER=custom
CHATBOT_MOCK_ONLY=false
CHATBOT_ALLOW_MOCK_FALLBACK=true
CHATBOT_TEMPERATURE=0.2
CUSTOM_PROVIDER_MODEL=qwen3-coder-480b-a35b-instruct

# Provider API keys
SHOPAIKEY_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0

# Storage
REDIS_URL=redis://localhost:6379/0
ALLOW_IN_MEMORY_SESSIONS=false
SESSION_TTL_SECONDS=86400

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
